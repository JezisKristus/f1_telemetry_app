# Generated .gitignore for a Python project (PyCharm / Windows / SQLite)
# Ignore Python bytecode
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
/.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
venv/
ENV/
env/
.venv/
env.bak/
venv.bak/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache/

# Translations
*.mo
*.pot

# Django/Pyramid/other local settings
local_settings.py
db.sqlite3

# Project SQLite and database files
# Ignore only database data files inside `database/` but keep project code there
database/*.db
database/*-journal
# Don't ignore Python/code files kept in `database/`
!database/*.py
!database/*.pyi
!database/*.sql
!database/*.md
!database/__init__.py

# (optional) root-level DB files (if you keep DB at repo root)
f1_telemetry.db
f1_telemetry.db-journal

# Flask instance folder
instance/

# Sphinx docs
docs/_build/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# PEP 582
__pypackages__/

# IDEs and editors
.idea/
*.iml
.vscode/
.vs/

# JetBrains specific caches
/.idea/workspace.xml
/.idea/tasks.xml
/.idea/usage.statistics.xml
/.idea/dictionaries/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# dotenv files with secrets
.env
.env.*

# Logs and databases
*.log
logs/
debug.log

# Mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# Celery
celerybeat-schedule

# Rope
.ropeproject/

# Editor backup files
*~
# End of .gitignore


